{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard", ":semanticCommits"],
  "timezone": "Europe/Paris",
  "schedule": ["before 6am on monday"],
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"]
  },
  "packageRules": [
    {
      "matchDepNames": ["node"],
      "matchManagers": ["nvm", "dockerfile", "docker-compose"],
      "groupName": "runtime Node",
      "commitMessageTopic": "Node"
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "actions GitHub",
      "automerge": true
    },
    {
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "automerge": true
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "devDependencies (non majeures)"
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"]
  }
}
