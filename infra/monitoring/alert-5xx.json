{
  "displayName": "Erreurs 5xx — plateforme & tenants",
  "combiner": "OR",
  "conditions": [
    {
      "displayName": "pfy-api / pfy-web : taux de 5xx élevé",
      "conditionThreshold": {
        "filter": "metric.type=\"run.googleapis.com/request_count\" resource.type=\"cloud_run_revision\" resource.label.\"service_name\"=monitoring.regex.full_match(\"pfy-(api|web)\") metric.label.\"response_code_class\"=\"5xx\"",
        "comparison": "COMPARISON_GT",
        "thresholdValue": 1,
        "duration": "300s",
        "trigger": { "count": 1 },
        "aggregations": [
          {
            "alignmentPeriod": "60s",
            "perSeriesAligner": "ALIGN_RATE",
            "crossSeriesReducer": "REDUCE_SUM"
          }
        ]
      }
    },
    {
      "displayName": "tenant-* : taux de 5xx élevé (un ou plusieurs tenants)",
      "conditionThreshold": {
        "filter": "metric.type=\"run.googleapis.com/request_count\" resource.type=\"cloud_run_revision\" resource.label.\"service_name\"=monitoring.regex.full_match(\"tenant-.*\") metric.label.\"response_code_class\"=\"5xx\"",
        "comparison": "COMPARISON_GT",
        "thresholdValue": 1,
        "duration": "300s",
        "trigger": { "count": 1 },
        "aggregations": [
          {
            "alignmentPeriod": "60s",
            "perSeriesAligner": "ALIGN_RATE",
            "crossSeriesReducer": "REDUCE_SUM"
          }
        ]
      }
    }
  ],
  "notificationChannels": ["__NOTIFICATION_CHANNEL__"],
  "alertStrategy": {
    "autoClose": "1800s"
  }
}
