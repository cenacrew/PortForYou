{
  "name": "portforyou",
  "version": "0.1.0",
  "private": true,
  "description": "Port'ForYou — plateforme SaaS de portfolios pour artistes visuels",
  "engines": {
    "node": ">=24.18.0"
  },
  "scripts": {
    "dev": "concurrently -n emu,shared,api,web -c yellow,gray,blue,magenta \"pnpm emulators:docker\" \"pnpm --filter @portforyou/shared dev\" \"pnpm --filter @portforyou/api dev\" \"pnpm --filter @portforyou/web dev\"",
    "emulators": "firebase emulators:start --only firestore,storage --project portforyou-vsp",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "emulators:docker": "docker compose up emulators",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^9.39.4",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "firebase-tools": "^15.22.4",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0"
  },
  "packageManager": "pnpm@11.10.0"
}
