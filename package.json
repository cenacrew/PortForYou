{
  "name": "portforyou",
  "version": "0.1.0",
  "private": true,
  "description": "Port'ForYou — plateforme SaaS de portfolios pour artistes visuels",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -n emu,shared,api,web -c yellow,gray,blue,magenta \"pnpm emulators:docker\" \"pnpm --filter @portforyou/shared dev\" \"pnpm --filter @portforyou/api dev\" \"pnpm --filter @portforyou/web dev\"",
    "emulators": "firebase emulators:start --only firestore,storage --project portforyou-vsp",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "emulators:docker": "docker compose up emulators",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^9.39.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "firebase-tools": "^14.19.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4"
  },
  "pnpm": {
    "overrides": {
      "tar@<6.2.2": ">=6.2.2"
    }
  }
}
