# Vitrine Port'ForYou
NEXT_PUBLIC_API_URL=http://localhost:8081
# URL publique de la vitrine (metadataBase, Open Graph, sitemap, robots)
NEXT_PUBLIC_SITE_URL=https://portforyou.web.app

# Error tracking (Sentry ou GlitchTip auto-hébergé) — vide = no-op (aucun envoi).
# DSN client (exposé au navigateur, public par nature). En prod : variable d'env.
NEXT_PUBLIC_SENTRY_DSN=
# DSN serveur/edge distinct (optionnel ; retombe sur le DSN public si vide).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
# Upload de sourcemaps au build (optionnel) — jamais commité, CI/Secret Manager.
# SENTRY_AUTH_TOKEN=
