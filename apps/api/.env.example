# API Port'ForYou
PORT=8081

# Origine autorisée (vitrine)
WEB_ORIGIN=http://localhost:3000

# Projet GCP/Firebase
GCP_PROJECT_ID=portforyou-vsp
GCP_REGION=europe-west1

# Drivers : fake = dev local sans compte externe
PAYMENT_DRIVER=fake
PROVISIONER_DRIVER=fake

# Stripe (mode test) — requis seulement si PAYMENT_DRIVER=stripe
# Créer produit/prix : STRIPE_SECRET_KEY=sk_test_... pnpm stripe-setup
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASE=
STRIPE_PRICE_DOMAIN=
STRIPE_PRICE_INFRA=

# Emails — vide = driver fake (log console)
RESEND_API_KEY=
MAIL_FROM=

# Error tracking (Sentry ou GlitchTip auto-hébergé) — vide = no-op (aucun envoi).
# En prod : DSN injecté depuis Secret Manager. Jamais commité (dépôt public).
SENTRY_DSN=
# Env rapporté (défaut : NODE_ENV) et taux d'échantillonnage des traces (0..1).
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0

# Dev local : émulateur Firestore (aucun credential requis)
# FIRESTORE_EMULATOR_HOST=localhost:8090

# Auth maison
JWT_SECRET=dev_secret_change_me
# OAuth Google (console.cloud.google.com > Identifiants) — vides = bouton inactif
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Provisioning GCP (PROVISIONER_DRIVER=gcp)
TEMPLATE_BUILDS_BUCKET=portforyou-template-builds
UPLOADS_BUCKET=portforyou-uploads
TEMPLATE_IMAGE_PATTERN=europe-west1-docker.pkg.dev/portforyou-vsp/pfy/{template}-back:latest
API_PUBLIC_URL=http://localhost:8081
TASKS_SERVICE_ACCOUNT=pfy-api@portforyou-vsp.iam.gserviceaccount.com
PROVISIONING_VIA_TASKS=0
# 1 = exiger un email vérifié avant de commander (activé en prod)
REQUIRE_VERIFIED_EMAIL=0
