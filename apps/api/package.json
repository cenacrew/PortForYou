{
  "name": "@portforyou/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "set-admin": "tsx scripts/set-admin.ts",
    "test:emu": "firebase emulators:exec --only firestore --project portforyou-vsp --config ../../firebase.json \"vitest run\"",
    "seed-demos": "tsx scripts/seed-demo-tenants.ts",
    "stripe-setup": "tsx scripts/stripe-setup.ts"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.21.0",
    "@portforyou/shared": "workspace:*",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^13.6.0",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "stripe": "^22.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.19.2",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.2.2",
    "tsx": "^4.20.7",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
