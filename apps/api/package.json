{
  "name": "@portforyou/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "set-admin": "tsx scripts/set-admin.ts",
    "test:emu": "firebase emulators:exec --only firestore --project portforyou-vsp --config ../../firebase.json \"vitest run\"",
    "seed-demos": "tsx scripts/seed-demo-tenants.ts",
    "stripe-setup": "tsx scripts/stripe-setup.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^9.0.0",
    "@google-cloud/storage": "^7.21.0",
    "@portforyou/shared": "workspace:*",
    "@sentry/node": "^10.66.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^14.1.0",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "stripe": "^22.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.13.2",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "supertest": "^7.2.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^6.4.3",
    "vitest": "^4.1.10"
  }
}
