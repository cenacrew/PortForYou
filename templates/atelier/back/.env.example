# Backend environment variables

# The port the Express server listens on
PORT=8080

# JWT configuration
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=1h

# Admin credentials (choose ONE of the following):
# Option A) Provide a bcrypt hash of the password
# ADMIN_PASSWORD_HASH=$2a$10$abcdefghijklmnopqrstuv...

# Option B) Provide a plain password (will be hashed at startup; for dev only)
# ADMIN_PASSWORD=admin123

# Admin email (used for login)
ADMIN_EMAIL=admin@example.com

# Firebase Admin credentials (for Firestore access)
# Obtain from the Firebase Console (Service accounts -> Generate new private key)
# Never commit your real private key to source control.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=

# --- Port'ForYou multi-tenant ---
# Identifiant du tenant servi par cette instance (injecté par le provisioning)
TENANT_ID=dev
# Instance de démonstration : back-office en lecture seule
DEMO_MODE=0

# Emails (Resend). Vide en dev = driver fake (log console)
RESEND_API_KEY=
MAIL_FROM=

# Dev local : émulateur Firestore (aucun credential Firebase requis)
# FIRESTORE_EMULATOR_HOST=localhost:8090
