rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Lecture publique des uploads des portfolios ; écriture via Admin SDK uniquement.
    match /tenants/{tenant}/uploads/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
